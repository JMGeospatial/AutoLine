              <item>
               <widget class="QLabel" name="label_depth_sampling">
                <property name="toolTip">
                 <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Resolution of along-line depth sampling for swath width estimation.&lt;/p&gt;&lt;p&gt;Lower values = more precise, but much slower.&lt;/p&gt;&lt;p&gt;For site characterization surveys 0.5-5 m is recommended.&lt;/p&gt;&lt;p&gt;For shelf-scale seabed mapping 10-50 m is recommended.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
                </property>
                <property name="text">
                 <string>Depth sampling distance interval for line spacing and coverage estimation (m):</string>
                </property>
               </widget>
              </item>
              <item>
               <widget class="QgsDoubleSpinBox" name="spinDepthSampling">
                <property name="toolTip">
                 <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Resolution of along-line depth sampling for swath width estimation. Max. = 100 m&lt;/p&gt;&lt;p&gt;Lower values = more precise, but much slower.&lt;/p&gt;&lt;p&gt;For site characterization surveys 0.5-5 m is recommended.&lt;/p&gt;&lt;p&gt;For shelf-scale seabed mapping 10-50 m is recommended.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
                </property>
                <property name="maximum">
