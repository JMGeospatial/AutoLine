                    <bool>true</bool>
                   </property>
                   <property name="toolTip">
                    <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Coverage estimation is approximate, does not take into account across swath swath width variability (e.g. slope), beam steering and is designed only for single-head MBES systems.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
